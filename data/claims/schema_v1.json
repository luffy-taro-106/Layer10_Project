{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Claim schema v1",
  "type": "object",
  "required": [
    "claim_id",
    "subject",
    "predicate",
    "object",
    "event_time",
    "valid_from",
    "confidence",
    "extraction_metadata",
    "evidence"
  ],
  "properties": {
    "claim_id": {"type": "string"},
    "subject": {"type": "string"},
    "predicate": {"type": "string"},
    "object": {"type": ["string", "object", "number"]},
    "event_time": {"type": ["string", "null"]},
    "valid_from": {"type": ["string", "null"]},
    "valid_to": {"type": ["string", "null"]},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "extraction_metadata": {
      "type": "object",
      "required": ["schema_version", "extractor_version", "extracted_at"],
      "properties": {
        "schema_version": {"type": "string"},
        "extractor_version": {"type": "string"},
        "model": {"type": ["string", "null"]},
        "prompt_version": {"type": ["string", "null"]},
        "extracted_at": {"type": "string"}
      }
    },
    "evidence": {
      "type": "object",
      "required": ["source_type", "source_id", "excerpt", "timestamp", "extraction"],
      "properties": {
        "source_type": {"type": "string"},
        "source_id": {},
        "excerpt": {"type": "string"},
        "location": {"type": ["string", "null"]},
        "offsets": {
          "type": ["object", "null"],
          "properties": {
            "char_start": {"type": ["integer", "null"]},
            "char_end": {"type": ["integer", "null"]}
          }
        },
        "timestamp": {"type": ["string", "null"]},
        "extraction": {
          "type": "object",
          "required": ["method", "timestamp"],
          "properties": {
            "method": {"type": "string"},
            "timestamp": {"type": "string"}
          }
        }
      }
    }
  }
}
