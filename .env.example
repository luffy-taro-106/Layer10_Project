# GitHub API
GITHUB_TOKEN=your_github_token_here
GITHUB_OWNER=apache
GITHUB_REPO=airflow

# Neo4j
NEO4J_USERNAME=your_neo4j_username_here
NEO4J_PASSWORD=your_neo4j_password_here
NEO4J_DATABASE=your_neo4j_database_here
NEO4J_URI=neo4j+s://{NEO4J_USERNAME}.databases.neo4j.io

# Optional (Aura)
AURA_INSTANCEID=your_aura_instance_id
